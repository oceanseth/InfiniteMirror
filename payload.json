{
  "slug": "hello-world-zero-mirrored",
  "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Zero • Hello World</title>\n  <meta name=\"description\" content=\"A visually stunning Hello World site hosted for free on Zero.\">\n  \n  <!-- Premium Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800&display=swap\" rel=\"stylesheet\">\n  \n  <style>\n    /* Reset and Base Styles */\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n    \n    :root {\n      --bg-primary: #05050a;\n      --bg-card: rgba(10, 11, 20, 0.45);\n      --border-color: rgba(255, 255, 255, 0.07);\n      --border-hover: rgba(99, 102, 241, 0.3);\n      --text-primary: #f3f4f6;\n      --text-secondary: #9ca3af;\n      --accent-indigo: #6366f1;\n      --accent-violet: #8b5cf6;\n      --accent-cyan: #06b6d4;\n    }\n    \n    body {\n      font-family: 'Inter', sans-serif;\n      background-color: var(--bg-primary);\n      color: var(--text-primary);\n      min-height: 100vh;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      overflow: hidden;\n      position: relative;\n    }\n\n    /* Ambient Background Glows */\n    .glow-orb {\n      position: absolute;\n      border-radius: 50%;\n      filter: blur(120px);\n      z-index: 0;\n      pointer-events: none;\n      opacity: 0.45;\n    }\n    \n    .glow-orb-1 {\n      width: 400px;\n      height: 400px;\n      background: radial-gradient(circle, var(--accent-indigo) 0%, rgba(99, 102, 241, 0) 70%);\n      top: -10%;\n      left: -10%;\n      animation: float-slow 15s infinite alternate ease-in-out;\n    }\n    \n    .glow-orb-2 {\n      width: 500px;\n      height: 500px;\n      background: radial-gradient(circle, var(--accent-violet) 0%, rgba(139, 92, 246, 0) 70%);\n      bottom: -15%;\n      right: -10%;\n      animation: float-slow 18s infinite alternate-reverse ease-in-out;\n    }\n    \n    .glow-orb-3 {\n      width: 300px;\n      height: 300px;\n      background: radial-gradient(circle, var(--accent-cyan) 0%, rgba(6, 182, 212, 0) 70%);\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      animation: pulse-slow 10s infinite ease-in-out;\n    }\n\n    @keyframes float-slow {\n      0% { transform: translateY(0px) scale(1); }\n      100% { transform: translateY(40px) scale(1.1); }\n    }\n    \n    @keyframes pulse-slow {\n      0%, 100% { opacity: 0.35; transform: translate(-50%, -50%) scale(1); }\n      50% { opacity: 0.55; transform: translate(-50%, -50%) scale(1.15); }\n    }\n\n    /* Interactive Glassmorphic Card */\n    .card {\n      background: var(--bg-card);\n      backdrop-filter: blur(20px) saturate(180%);\n      -webkit-backdrop-filter: blur(20px) saturate(180%);\n      border: 1px solid var(--border-color);\n      border-radius: 24px;\n      padding: 3rem 2.5rem;\n      max-width: 480px;\n      width: 90%;\n      text-align: center;\n      position: relative;\n      z-index: 10;\n      box-shadow: \n        0 4px 30px rgba(0, 0, 0, 0.4),\n        inset 0 1px 1px rgba(255, 255, 255, 0.1);\n      transition: border-color 0.4s ease, box-shadow 0.4s ease, transform 0.3s ease;\n    }\n    \n    .card:hover {\n      border-color: var(--border-hover);\n      box-shadow: \n        0 10px 40px rgba(0, 0, 0, 0.5),\n        0 0 40px rgba(99, 102, 241, 0.15),\n        inset 0 1px 1px rgba(255, 255, 255, 0.15);\n      transform: translateY(-4px);\n    }\n    \n    /* Live Status Badge */\n    .status-badge {\n      display: inline-flex;\n      align-items: center;\n      gap: 0.5rem;\n      background: rgba(99, 102, 241, 0.1);\n      border: 1px solid rgba(99, 102, 241, 0.2);\n      border-radius: 100px;\n      padding: 0.35rem 0.85rem;\n      font-size: 0.75rem;\n      font-weight: 500;\n      color: #a5b4fc;\n      margin-bottom: 1.5rem;\n      letter-spacing: 0.05em;\n      text-transform: uppercase;\n    }\n    \n    .status-dot {\n      width: 6px;\n      height: 6px;\n      background-color: var(--accent-cyan);\n      border-radius: 50%;\n      position: relative;\n    }\n    \n    .status-dot::after {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      border-radius: 50%;\n      background-color: var(--accent-cyan);\n      animation: ripple 1.6s infinite ease-out;\n    }\n    \n    @keyframes ripple {\n      0% { transform: scale(1); opacity: 1; }\n      100% { transform: scale(3.5); opacity: 0; }\n    }\n\n    /* Typography */\n    h1 {\n      font-family: 'Outfit', sans-serif;\n      font-size: 2.75rem;\n      font-weight: 800;\n      line-height: 1.15;\n      margin-bottom: 1rem;\n      background: linear-gradient(135deg, #ffffff 30%, #a5b4fc 70%, var(--accent-indigo) 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      letter-spacing: -0.02em;\n    }\n    \n    .subtitle {\n      color: var(--text-secondary);\n      font-size: 1rem;\n      line-height: 1.5;\n      margin-bottom: 2rem;\n      font-weight: 300;\n    }\n\n    /* Profile Wallet display */\n    .wallet-box {\n      background: rgba(255, 255, 255, 0.03);\n      border: 1px solid rgba(255, 255, 255, 0.05);\n      border-radius: 12px;\n      padding: 0.75rem 1rem;\n      margin-bottom: 2rem;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0.25rem;\n    }\n\n    .wallet-label {\n      font-size: 0.65rem;\n      text-transform: uppercase;\n      letter-spacing: 0.1em;\n      color: var(--text-secondary);\n    }\n\n    .wallet-address {\n      font-family: monospace;\n      font-size: 0.85rem;\n      color: #e5e7eb;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      gap: 0.35rem;\n      transition: color 0.2s ease;\n    }\n\n    .wallet-address:hover {\n      color: var(--accent-cyan);\n    }\n\n    .wallet-address svg {\n      width: 14px;\n      height: 14px;\n      fill: none;\n      stroke: currentColor;\n      stroke-width: 2;\n    }\n    \n    /* Interactive Button Group */\n    .btn-group {\n      display: flex;\n      flex-direction: column;\n      gap: 0.75rem;\n    }\n    \n    .btn {\n      width: 100%;\n      padding: 0.85rem 1.5rem;\n      border-radius: 12px;\n      font-size: 0.9rem;\n      font-weight: 600;\n      text-decoration: none;\n      transition: all 0.3s ease;\n      cursor: pointer;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 0.5rem;\n    }\n    \n    .btn-primary {\n      background: linear-gradient(135deg, var(--accent-indigo), var(--accent-violet));\n      color: white;\n      border: none;\n      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);\n    }\n    \n    .btn-primary:hover {\n      transform: translateY(-1px);\n      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.45);\n      background: linear-gradient(135deg, #4f46e5, #7c3aed);\n    }\n    \n    .btn-secondary {\n      background: rgba(255, 255, 255, 0.05);\n      color: var(--text-primary);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n    \n    .btn-secondary:hover {\n      background: rgba(255, 255, 255, 0.08);\n      border-color: rgba(255, 255, 255, 0.15);\n    }\n\n    /* Toast Notification for Clipboard Copy */\n    .toast {\n      position: fixed;\n      bottom: 2rem;\n      left: 50%;\n      transform: translateX(-50%) translateY(100px);\n      background: rgba(10, 11, 20, 0.9);\n      border: 1px solid var(--accent-cyan);\n      border-radius: 100px;\n      padding: 0.6rem 1.2rem;\n      font-size: 0.8rem;\n      color: var(--text-primary);\n      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);\n      opacity: 0;\n      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;\n      z-index: 100;\n      display: flex;\n      align-items: center;\n      gap: 0.5rem;\n    }\n\n    .toast.show {\n      transform: translateX(-50%) translateY(0);\n      opacity: 1;\n    }\n\n    /* Footer Credits */\n    footer {\n      position: absolute;\n      bottom: 1.5rem;\n      left: 50%;\n      transform: translateX(-50%);\n      font-size: 0.7rem;\n      color: rgba(255, 255, 255, 0.25);\n      letter-spacing: 0.05em;\n      z-index: 10;\n      text-align: center;\n    }\n\n    footer a {\n      color: rgba(255, 255, 255, 0.4);\n      text-decoration: none;\n      transition: color 0.2s ease;\n    }\n\n    footer a:hover {\n      color: var(--accent-cyan);\n    }\n  </style>\n</head>\n<body>\n\n  <!-- Background Orbs -->\n  <div class=\"glow-orb glow-orb-1\"></div>\n  <div class=\"glow-orb glow-orb-2\"></div>\n  <div class=\"glow-orb glow-orb-3\"></div>\n\n  <!-- Main Card -->\n  <div class=\"card\">\n    <div class=\"status-badge\">\n      <span class=\"status-dot\"></span>\n      <span id=\"time-greeting\">Hello, World!</span>\n    </div>\n    \n    <h1>Hello, World.</h1>\n    <p class=\"subtitle\">This elegant webpage was built by Antigravity and is deployed instantly to the edge using the ZeroClick platform.</p>\n    \n    <!-- Wallet box -->\n    <div class=\"wallet-box\">\n      <span class=\"wallet-label\">Connected Zero Wallet</span>\n      <div class=\"wallet-address\" onclick=\"copyWalletAddress()\" title=\"Click to copy address\">\n        <span id=\"wallet-text\">0x3dEF...0FD6</span>\n        <svg viewBox=\"0 0 24 24\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" ry=\"2\"></rect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"></path></svg>\n      </div>\n    </div>\n    \n    <!-- Button group -->\n    <div class=\"btn-group\">\n      <a class=\"btn btn-primary\" href=\"https://zero.xyz\" target=\"_blank\">\n        Explore Zero\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>\n      </a>\n      <button class=\"btn btn-secondary\" onclick=\"triggerInteractiveGreeting()\">\n        Interact\n      </button>\n    </div>\n  </div>\n\n  <!-- Toast notification -->\n  <div class=\"toast\" id=\"toast\">\n    <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#06b6d4\" stroke-width=\"2\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg>\n    <span>Wallet address copied!</span>\n  </div>\n\n  <!-- Footer -->\n  <footer>\n    Powered by <a href=\"https://zero.xyz\" target=\"_blank\">Zero</a> &amp; Antigravity Agent\n  </footer>\n\n  <script>\n    const fullWalletAddress = \"0x3dEF78C89327eB05531Daedb4eC3Dd5287F10FD6\";\n\n    // Set time-based greeting dynamically\n    function getGreeting() {\n      const hrs = new Date().getHours();\n      if (hrs < 12) return \"Good Morning • Live on Zero\";\n      if (hrs < 18) return \"Good Afternoon • Live on Zero\";\n      return \"Good Evening • Live on Zero\";\n    }\n    \n    document.getElementById('time-greeting').innerText = getGreeting();\n\n    // Clipboard Copy\n    function copyWalletAddress() {\n      navigator.clipboard.writeText(fullWalletAddress).then(() => {\n        const toast = document.getElementById('toast');\n        toast.classList.add('show');\n        setTimeout(() => {\n          toast.classList.remove('show');\n        }, 2500);\n      });\n    }\n\n    // Interactive button demo\n    let interactCount = 0;\n    const greetings = [\n      \"Welcome to the future of AI Agent hosting!\",\n      \"Zero makes hosting free and instant.\",\n      \"Hello again, traveler of the digital space!\",\n      \"You clicked it! The interface is fully alive.\",\n      \"Antigravity + Zero = Infinite Possibilities ✨\"\n    ];\n\n    function triggerInteractiveGreeting() {\n      interactCount++;\n      const textElement = document.querySelector('.subtitle');\n      textElement.style.opacity = 0;\n      \n      setTimeout(() => {\n        textElement.innerText = greetings[(interactCount - 1) % greetings.length];\n        textElement.style.opacity = 1;\n        textElement.style.transition = \"opacity 0.3s ease\";\n      }, 200);\n    }\n  </script>\n</body>\n</html>\n",
  "ttlHours": 336
}