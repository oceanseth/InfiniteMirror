# Copy to ../../.env (repo root) or export these before running the bridge.
# NEVER commit real values. The repo-root .env is gitignored.

# Masky API key — held ONLY by the bridge process; never exposed to the agent.
# Rotate in the Masky dashboard if it was ever pasted in plaintext.
MASKY_API_KEY=mky_your_rotated_key_here

# Optional bridge bind overrides (defaults shown). Compose sets BRIDGE_HOST=0.0.0.0.
# BRIDGE_PORT=8080
# BRIDGE_HOST=127.0.0.1

# --- Pomerium Zero (used by docker-compose, NOT by the bridge) -------------------------------
# Cluster CONNECTION token from console.pomerium.app -> your cluster -> "Connect".
# This is NOT the same as the Zero management API key.
POMERIUM_ZERO_TOKEN=paste_cluster_connection_token_here
